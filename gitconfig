[user]
	name = Robert Kluin
	email = robert.kluin@realkinetic.com

[core]
	excludesfile = /Users/bobert/.gitignore_global
    autocrlf = input
    editor = vim

[color]
    diff = auto
    status = auto
    branch = auto

[diff]
    algorithm = histogram
    colorMoved = plain
    renames = true

[alias]
  st = status
  di = diff
  co = checkout
  ci = commit
  br = branch
  sta = stash
  an = annotate

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true
    all = true

[merge]
    tool = vimdiff

[rebase]
    autoStash = true
    updateRefs = true

[commit]
	gpgsign = true
	verbose = true

[init]
	defaultBranch = main
